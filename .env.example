APP_NAME=Travel Agent MVP
APP_ENV=local
DATABASE_PATH=data/travel_agent.sqlite3
VECTOR_STORE_PATH=data/vector_store
DEFAULT_USE_MOCK=false

# Optional OpenAI-compatible live mode.
# Leave unset for the default deterministic mock/fallback flow.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional MediaCrawler adapter configuration.
MEDIA_CRAWLER_ROOT=external/MediaCrawler
MEDIA_CRAWLER_RUNNER=uv run
MEDIA_CRAWLER_LOGIN_TYPE=qrcode
MEDIA_CRAWLER_SAVE_OPTION=jsonl
MEDIA_CRAWLER_HEADLESS=false
MEDIA_CRAWLER_RUNS_PATH=data/media_crawler_runs
MEDIA_CRAWLER_WORKDIR=
MEDIA_CRAWLER_SLEEP_SECONDS=1.0
MEDIA_CRAWLER_RATE_LIMIT_PER_MINUTE=10
MEDIA_CRAWLER_TIMEOUT_SECONDS=120
MEDIA_CRAWLER_REQUIRE_INITIALIZED=true
MEDIA_CRAWLER_INIT_STATUS_PATH=data/media_crawler_init/status.json
